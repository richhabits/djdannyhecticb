# DJ Danny Hectic B - Vercel Environment Variables
# Add these to Vercel Project Settings → Environment Variables
# Mark sensitive variables as "Sensitive" (encrypted at rest)
# Set scope to "Production" for production-only secrets

# ============================================================================
# CRITICAL (Must be set for production)
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
JWT_SECRET=your-very-strong-random-secret-minimum-32-characters-long

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=https://djdannyhecticb.com,https://www.djdannyhecticb.com,https://api.djdannyhecticb.com

# ============================================================================
# OAuth Configuration
# ============================================================================
OAUTH_SERVER_URL=https://oauth.example.com
VITE_OAUTH_PORTAL_URL=https://oauth.example.com/portal
VITE_APP_ID=your-app-id

# ============================================================================
# Stripe Payment Processing (if using Stripe)
# ============================================================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# PayPal Configuration (if using PayPal)
# ============================================================================
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live
# PAYPAL_MODE=sandbox  # For testing

# ============================================================================
# Optional: Google Places API (for location features)
# ============================================================================
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ============================================================================
# Optional: Admin Features
# ============================================================================
OWNER_OPEN_ID=your-owner-id

# ============================================================================
# Optional: Internal/Forge API
# ============================================================================
BUILT_IN_FORGE_API_URL=https://api.internal.example.com
BUILT_IN_FORGE_API_KEY=your-internal-api-key

# ============================================================================
# Note: NODE_ENV is automatically set to "production" by vercel.json
# Do NOT set it here
# ============================================================================
