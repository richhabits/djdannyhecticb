# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# Variable Status Legend:
# [REQUIRED] - Must be set in production
# [OPTIONAL] - Nice to have, has sensible defaults
# [DEV-ONLY] - Development/testing only

# ============================================
# Core Server Configuration
# ============================================

# Node Environment [OPTIONAL]
# Controls debug output, error handling, and feature flags
# Values: development | production
NODE_ENV=development

# Server Port [OPTIONAL]
# The port the Express server listens on
# Defaults to 3000 if not set
PORT=3000

# Offline Mode [OPTIONAL]
# Set to "1" to disable external API calls and OAuth
# Useful for local development without internet requirements
OFFLINE_MODE=0

# ============================================
# Database Configuration (Postgres/Supabase)
# ============================================

# Database Connection URL [REQUIRED in production]
# PostgreSQL connection string for Drizzle ORM
# Format: postgresql://user:password@host:port/database
# Example: postgresql://admin:pass123@localhost:5432/djdannyhecticb
DATABASE_URL=postgresql://localhost:5432/djdannyhecticb

# ============================================
# Authentication & Session Management
# ============================================

# JWT Secret [REQUIRED in production]
# Secret key for signing and verifying JWT tokens
# IMPORTANT: Must be at least 32 characters in production for security
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production

# OAuth Server URL [REQUIRED if using OAuth]
# Base URL of your OAuth authentication server
# Examples: https://auth.example.com, http://localhost:3000
OAUTH_SERVER_URL=http://localhost:3000

# Application ID / Client ID [REQUIRED if using OAuth]
# OAuth application/client ID used for authentication
# Used by both backend and frontend
APP_ID=your-oauth-app-id

# Alternative App ID for Frontend [OPTIONAL]
# Frontend can use this if different from backend
# Vite only exposes variables prefixed with VITE_
VITE_APP_ID=your-vite-app-id

# Owner OpenID [OPTIONAL]
# OpenID identifier of the application owner/admin
# Used to identify admin users in the system
OWNER_OPEN_ID=

# Server Salt [OPTIONAL]
# Additional salt for hashing analytics data
# If not set, falls back to SESSION_SECRET, then JWT_SECRET
SERVER_SALT=

# Session Secret [OPTIONAL]
# Legacy session/salt fallback used in analytics
# If SERVER_SALT not set, this is used as fallback
SESSION_SECRET=

# ============================================
# CORS Configuration
# ============================================

# CORS Allowed Origins [OPTIONAL]
# Comma-separated list of allowed origins for CORS requests
# Example: http://localhost:3000,https://example.com,https://app.example.com
# Defaults to http://localhost:3000 for local development
CORS_ORIGINS=http://localhost:3000

# ============================================
# Payment Integration - Stripe
# ============================================

# Stripe Publishable Key [OPTIONAL]
# Public API key for Stripe (safe to expose in frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Secret Key [OPTIONAL]
# Secret API key for Stripe (keep private, backend only)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret [OPTIONAL]
# Webhook signing secret for Stripe event verification
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Payment Integration - PayPal
# ============================================

# PayPal Client ID [OPTIONAL]
# OAuth 2.0 client ID from PayPal Developer Dashboard
PAYPAL_CLIENT_ID=

# PayPal Client Secret [OPTIONAL]
# OAuth 2.0 client secret from PayPal Developer Dashboard
PAYPAL_CLIENT_SECRET=

# PayPal Mode [OPTIONAL]
# Payment mode for PayPal integration
# Values: sandbox (testing) | live (production)
# Defaults to sandbox
PAYPAL_MODE=sandbox

# ============================================
# AWS S3 Configuration
# ============================================

# AWS Access Key ID [OPTIONAL]
# AWS IAM access key for S3 operations
# Get from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key [OPTIONAL]
# AWS IAM secret access key for S3 operations
# Get from: https://console.aws.amazon.com/iam/
AWS_SECRET_ACCESS_KEY=

# AWS S3 Bucket Name [OPTIONAL]
# Name of the S3 bucket for file storage
# Example: djdannyhecticb-files, my-app-bucket
AWS_S3_BUCKET=

# AWS Region [OPTIONAL]
# AWS region where S3 bucket is located
# Defaults to us-east-1 if not set
# Example values: us-east-1, us-west-2, eu-west-1, ap-southeast-1
AWS_REGION=us-east-1

# ============================================
# AI & Language Model Configuration
# ============================================

# Primary AI API Key [REQUIRED for AI features]
# Generic API key for AI operations (used by multiple AI modules)
# This key is referenced by aiBooking, aiMixGenerator, aiReacts, etc.
AI_API_KEY=

# Primary AI Model [OPTIONAL]
# Default model name for generic AI operations
AI_MODEL=gpt-3.5-turbo

# ============================================
# Google AI (Gemini)
# ============================================

# Google AI API Key [OPTIONAL]
# API key for Google's Gemini models (free tier available)
# Get from: https://aistudio.google.com/apikey
# Used for show summaries, text generation, and analyses
GOOGLE_AI_API_KEY=

# Gemini Model [OPTIONAL]
# Specific Gemini model to use
# Recommended: gemini-1.5-flash (fast, free tier)
# Alternative: gemini-1.5-pro (more capable)
# Defaults to gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-flash

# ============================================
# Open Source AI Providers
# ============================================

# Groq API Key [OPTIONAL]
# API key for Groq (ultra-fast open-source inference)
# Get from: https://console.groq.com/keys
# Note: Groq offers very fast inference at no cost
GROQ_API_KEY=

# Groq Model [OPTIONAL]
# Model to use with Groq
# Recommended: llama-3.1-8b-instant (fast, multilingual)
# Defaults to llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant

# Cohere API Key [OPTIONAL]
# API key for Cohere (free tier available)
# Get from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Cohere Model [OPTIONAL]
# Model to use with Cohere
# Defaults to command (v4)
COHERE_MODEL=command

# Hugging Face API Key [OPTIONAL]
# API key for Hugging Face Inference API
# Get from: https://huggingface.co/settings/tokens
# Free tier available for API access
HUGGINGFACE_API_KEY=

# Hugging Face Model [OPTIONAL]
# Model identifier on Hugging Face Hub
# Recommended: meta-llama/Llama-3.1-8B-Instruct
# Defaults to meta-llama/Llama-3.1-8B-Instruct
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ============================================
# Local AI Models (Ollama)
# ============================================

# Ollama URL [OPTIONAL]
# Base URL for local Ollama instance
# Defaults to http://localhost:11434
# Set this if running Ollama locally for completely free AI
OLLAMA_URL=http://localhost:11434

# Ollama Model [OPTIONAL]
# Model name to use with Ollama
# Recommended: llama3, mistral, neural-chat
# Defaults to llama3
# Install via: ollama pull llama3
OLLAMA_MODEL=llama3

# ============================================
# Future/Experimental AI Providers (Commented Out)
# ============================================
# The following are experimental or future integrations currently commented out in the code
# Uncomment and configure if you wish to use these providers

# DID.com API Key [OPTIONAL - Currently Commented Out]
# API key for DID.com video generation service
# Get from: https://www.did.com
# Used for avatar/video generation features
# DID_API_KEY=

# ElevenLabs API Key [OPTIONAL - Currently Commented Out]
# API key for ElevenLabs text-to-speech service
# Get from: https://elevenlabs.io
# Used for voice synthesis and audio generation
# ELEVENLABS_API_KEY=

# OpenAI API Key [OPTIONAL - Currently Commented Out]
# API key for OpenAI (GPT models)
# Get from: https://platform.openai.com/api-keys
# Can be used as alternative to free providers
# OPENAI_API_KEY=

# ============================================
# Third-Party API Integrations
# ============================================

# Google Places API Key [OPTIONAL]
# API key for Google Places API (venue lookup, geolocation)
# Get from: https://console.cloud.google.com/
# Used for searching and validating venue locations
GOOGLE_PLACES_API_KEY=

# Ticketmaster API Key [REQUIRED for event feed]
# API key for Ticketmaster Discovery API (production events integration)
# Get from: https://developer.ticketmaster.com/
# Used for fetching UK events, ticket status, pricing, and venue information
# Required to enable live event synchronization
TICKETMASTER_API_KEY=

# ============================================
# Forge API Configuration (Internal)
# ============================================

# Forge API URL [OPTIONAL]
# Base URL for the built-in Forge API
# Example: https://forge.example.com/api
BUILT_IN_FORGE_API_URL=

# Forge API Key [OPTIONAL]
# API key for authenticating with Forge API
BUILT_IN_FORGE_API_KEY=

# ============================================
# Integrations & Security
# ============================================

# Integrations Master Key [OPTIONAL]
# Master key for encrypting/decrypting integration secrets
# Generate a strong random string for production
# Used when NODE_ENV is production
INTEGRATIONS_MASTER_KEY=

# ============================================
# Base URL Configuration
# ============================================

# Base URL [OPTIONAL]
# The base URL of your application (for SEO, redirects, etc.)
# Defaults to https://djdannyhecticb.com
# Used in SEO metadata and canonical URLs
BASE_URL=https://djdannyhecticb.com

# ============================================
# Frontend (Vite) Configuration
# ============================================
# Note: Vite only exposes variables prefixed with VITE_ to the client

# OAuth Portal URL [OPTIONAL]
# URL of the OAuth portal for frontend login flows
# Should match OAUTH_SERVER_URL or point to your portal
# Example: https://auth.example.com/portal
VITE_OAUTH_PORTAL_URL=http://localhost:3000

# Alternative OAuth Server URL [OPTIONAL]
# Alternative naming for OAUTH_SERVER_URL if needed
VITE_OAUTH_SERVER_URL=http://localhost:3000

# Application Title [OPTIONAL]
# Brand name displayed in the UI
# Defaults to "DJ Danny Hectic B"
VITE_APP_TITLE=DJ Danny Hectic B

# Application Logo [OPTIONAL]
# Path to the application logo (relative or absolute URL)
# Defaults to /logo-icon.png
VITE_APP_LOGO=/logo-icon.png

# ============================================
# Analytics Configuration (Frontend)
# ============================================

# Analytics Endpoint [OPTIONAL]
# URL endpoint for analytics events
# Defaults to /analytics for local development
# Set to a real analytics service URL in production
VITE_ANALYTICS_ENDPOINT=/analytics

# Analytics Website ID [OPTIONAL]
# Identifier for this website in the analytics service
# Defaults to local-dev
# Should be a unique ID in production
VITE_ANALYTICS_WEBSITE_ID=local-dev

# ============================================
# Live Streaming Configuration
# ============================================

# Hectic Radio Stream URL [OPTIONAL]
# The live audio stream URL for the radio player
# Examples:
#   - https://stream.example.com/hectic-radio
#   - http://icecast.example.com:8000/hectic
#   - https://shoutcast.example.com/stream
# For local development, can be a placeholder (player shows but won't play)
VITE_HECTIC_RADIO_STREAM_URL=

# ============================================
# Development / Admin Credentials
# ============================================

# Admin Email [OPTIONAL]
# Email for the default admin user (development/seeding only)
# Defaults to admin@djdannyhecticb.co.uk
ADMIN_EMAIL=admin@djdannyhecticb.co.uk

# Admin Password [OPTIONAL]
# Password for the default admin user (development/seeding only)
# IMPORTANT: Change this in production if seeding is enabled
# Defaults to DannyHectic2024!
ADMIN_PASSWORD=DannyHectic2024!

# ============================================
# Example Multi-Value Configuration
# ============================================

# For CORS_ORIGINS with multiple values:
# CORS_ORIGINS=http://localhost:3000,https://example.com,https://app.example.com

# For multiple stream URLs (if supported):
# VITE_HECTIC_RADIO_STREAM_URL=https://primary-stream.com/hectic,https://backup-stream.com/hectic

# ============================================
# SMS & Voice Integration (Telnyx)
# ============================================

# Telnyx API Key [OPTIONAL]
# API key for Telnyx SMS and voice call integration
# Get from: https://telnyx.com/account/keys
TELNYX_API_KEY=

# Telnyx Public Key [OPTIONAL]
# Public key for Telnyx webhook verification
# Get from: https://telnyx.com/account/settings
TELNYX_PUBLIC_KEY=

# Telnyx Phone Number [OPTIONAL]
# Your Telnyx phone number for outbound SMS/calls
# Format: +1234567890
TELNYX_PHONE_NUMBER=

# ============================================
# Voice AI Integration (Vapi)
# ============================================

# Vapi API Key [OPTIONAL]
# API key for Vapi voice AI assistant integration
# Get from: https://vapi.ai/dashboard
VAPI_API_KEY=

# Vapi Phone Number [OPTIONAL]
# Your Vapi phone number for inbound/outbound calls
# Format: +1234567890
VAPI_PHONE_NUMBER=

# Vapi Assistant ID [OPTIONAL]
# ID of your configured Vapi assistant
# Get from: https://vapi.ai/dashboard/assistants
VAPI_ASSISTANT_ID=

# ============================================
# Cron & Background Jobs
# ============================================

# Cron Secret [OPTIONAL]
# Secret token for Vercel cron endpoints
# Generate: openssl rand -hex 32
# Only needed if cron jobs are enabled
CRON_SECRET=

# ============================================
# Music Platform Integrations
# ============================================

# Spotify Client ID [OPTIONAL]
# OAuth 2.0 client ID from Spotify Developer Dashboard
# Get from: https://developer.spotify.com/dashboard
# Used for fetching artist releases and albums
SPOTIFY_CLIENT_ID=

# Spotify Client Secret [OPTIONAL]
# OAuth 2.0 client secret from Spotify Developer Dashboard
# Keep private - backend only
SPOTIFY_CLIENT_SECRET=

# Spotify Artist ID [OPTIONAL]
# Your artist ID on Spotify
# Format: 32-character alphanumeric string
# Find at: https://open.spotify.com/artist/YOUR_ID_HERE
SPOTIFY_ARTIST_ID=

# SoundCloud Client ID [OPTIONAL]
# OAuth 2.0 client ID from SoundCloud Developers
# Get from: https://soundcloud.com/settings/applications
# Used for fetching track listings
SOUNDCLOUD_CLIENT_ID=

# SoundCloud User ID [OPTIONAL]
# Your user ID on SoundCloud
# Format: numeric identifier
# Find at: https://api.soundcloud.com/resolve?url=https://soundcloud.com/YOUR_USERNAME
SOUNDCLOUD_USER_ID=

# ============================================
# Print & Merchandise Integrations
# ============================================

# Printfull API Key [OPTIONAL]
# API key for Printfull print-on-demand integration
# Get from: https://www.printfull.com/account/integrations
# Used for merchandise orders and shipping
PRINTFULL_API_KEY=

# ============================================
# Email & Notifications
# ============================================

# Email Service Provider [OPTIONAL]
# Email service to use for notifications
# Values: sendgrid | mailgun | aws-ses | smtp
# Defaults to sendgrid
EMAIL_SERVICE_PROVIDER=sendgrid

# Email API Key [OPTIONAL]
# API key for the chosen email service provider
# SendGrid: https://app.sendgrid.com/settings/api_keys
# Mailgun: https://app.mailgun.com/app/account/security/api_keys
# AWS SES: Use AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
EMAIL_API_KEY=

# Email From Address [OPTIONAL]
# Sender email address for transactional emails
# Example: noreply@djdannyhectic.com
# Make sure this is verified with your email provider
EMAIL_FROM_ADDRESS=noreply@djdannyhectic.com

# Email From Domain [OPTIONAL]
# Domain for email authentication (SPF, DKIM)
# Example: djdannyhectic.com
# Used for email provider configuration
EMAIL_FROM_DOMAIN=djdannyhectic.com

# Notifications Email [OPTIONAL]
# Internal email address for system notifications and alerts
# Example: notifications@djdannyhectic.com
# Receives booking confirmations, contact form submissions, etc.
NOTIFICATIONS_EMAIL=

# ============================================
# Social Media & Contact Links
# ============================================

# Beatport Profile URL [OPTIONAL]
# Link to your Beatport artist profile
# Format: https://www.beatport.com/artist/YOUR_NAME/ARTIST_ID
# Used in footer links and profile pages
BEATPORT_PROFILE_URL=

# Phone Number [OPTIONAL]
# Contact phone number for the artist
# Format: +44 (for UK), or international format
# Used in contact forms and booking information
PHONE_NUMBER=07957432842

# Instagram Handle [OPTIONAL]
# Instagram username (without @)
# Example: djdannyhecticb
# Used in social media links and contact footer
INSTAGRAM_HANDLE=djdannyhecticb
