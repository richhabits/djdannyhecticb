# Staging Environment Configuration
# Copy this to Railway staging project environment variables

# === Core URLs ===
BASE_URL="https://staging.djdannyhecticb.com"
FRONTEND_URL="https://staging.djdannyhecticb.com"
API_URL="https://staging-api.djdannyhecticb.com"

# === Database ===
# Set to your Railway PostgreSQL connection string
DATABASE_URL="postgresql://user:password@staging-db.railway.app/djdannyhectic"

# === Authentication ===
JWT_SECRET="[GENERATE-STAGING-SECRET-64-CHARS-MIN]"
COOKIE_DOMAIN=".staging.djdannyhecticb.com"
SESSION_SECRET="[GENERATE-STAGING-SESSION-64-CHARS]"

# === OAuth - Google ===
GOOGLE_CLIENT_ID="[STAGING-GOOGLE-CLIENT-ID]"
GOOGLE_CLIENT_SECRET="[STAGING-GOOGLE-CLIENT-SECRET]"
GOOGLE_CALLBACK_URL="https://staging.djdannyhecticb.com/api/oauth/google/callback"

# === OAuth - Twitch ===
TWITCH_CLIENT_ID="[STAGING-TWITCH-ID]"
TWITCH_CLIENT_SECRET="[STAGING-TWITCH-SECRET]"

# === Payments - Stripe (Sandbox) ===
STRIPE_PUBLISHABLE_KEY="pk_test_[STAGING-STRIPE-PK]"
STRIPE_SECRET_KEY="sk_test_[STAGING-STRIPE-SK]"
STRIPE_WEBHOOK_SECRET="whsec_test_[STAGING-STRIPE-WEBHOOK]"

# === Payments - PayPal (Sandbox) ===
PAYPAL_CLIENT_ID="[STAGING-PAYPAL-CLIENT-ID]"
PAYPAL_CLIENT_SECRET="[STAGING-PAYPAL-SECRET]"
PAYPAL_MODE="sandbox"

# === Integrations - APIs ===
TICKETMASTER_API_KEY="[STAGING-TICKETMASTER-KEY]"
YOUTUBE_API_KEY="[STAGING-YOUTUBE-KEY]"
YOUTUBE_DATA_API_KEY="[STAGING-YOUTUBE-DATA-KEY]"
SPOTIFY_CLIENT_ID="[STAGING-SPOTIFY-ID]"
SPOTIFY_CLIENT_SECRET="[STAGING-SPOTIFY-SECRET]"

# === AI / LLM ===
GOOGLE_AI_API_KEY="[STAGING-GEMINI-API-KEY]"

# === Infrastructure ===
NODE_ENV="staging"
TURBO_CACHE="remote:rw"
TURBO_RUN_SUMMARY="true"
LOG_LEVEL="info"

# === Optional - Redis (if needed) ===
REDIS_URL=""

# === CORS ===
ALLOWED_ORIGINS="https://staging.djdannyhecticb.com,https://staging-api.djdannyhecticb.com,http://localhost:3000,http://localhost:5173"

# === Email (Optional) ===
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply-staging@djdannyhecticb.com"

# === Monitoring ===
SENTRY_DSN=""
SENTRY_ENVIRONMENT="staging"

# === Feature Flags ===
ENABLE_ANALYTICS="true"
ENABLE_WEBHOOKS="true"
ENABLE_PAYMENTS="true"
ENABLE_BROADCAST="true"
